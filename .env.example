# ==============================================================================
# AttendX Environment Variables
# Copy this file to backend/.env and fill in the values
# ==============================================================================

# -- Database ------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://attendx:password@localhost:5432/attendx
DATABASE_URL_SYNC=postgresql://attendx:password@localhost:5432/attendx
POSTGRES_USER=attendx
POSTGRES_PASSWORD=password
POSTGRES_DB=attendx

# -- Redis ---------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -- Security ------------------------------------------------------------------
SECRET_KEY=22mkr25dom32kv
JWT_SECRET=22mkr25dom32kv
JWT_ACCESS_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=7

# -- Telegram ------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=AttendXBot
ADMIN_CHAT_ID=0
WEBHOOK_DOMAIN=

# -- Encryption ----------------------------------------------------------------
FERNET_KEY=22mkr25dom32kv

# -- API Keys ------------------------------------------------------------------
API_KEY_HEADER=X-API-Key
DEFAULT_API_KEY=your-initial-api-key

# -- Monitoring ----------------------------------------------------------------
SENTRY_DSN=

# -- CORS ----------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# -- Hikvision -----------------------------------------------------------------
HIKVISION_POLL_INTERVAL=5

# -- Metrics -------------------------------------------------------------------
ENABLE_METRICS=false

# -- Application ---------------------------------------------------------------
APP_NAME=AttendX
APP_VERSION=1.0.0
LOG_LEVEL=DEBUG
APP_ENV=development
DEBUG=true
